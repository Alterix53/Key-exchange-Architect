DB_SERVER=localhost
DB_NAME=IAM_KMS_DB
DB_USE_WINDOWS_AUTH=True
DB_USER=
DB_PASSWORD=

# Security mode: "demo" (default) or "secure"
IAM_SECURITY_MODE=demo
# Passphrase to encrypt PKI private keys on disk (required in secure mode)
IAM_PKI_PASSPHRASE=
# Passphrase to wrap master key in DB (required in secure mode)
IAM_MASTER_KEY_PASSPHRASE=
